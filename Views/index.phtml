<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Gestión de Productos</title>
    <style>
        body { font-family: Arial, sans-serif; max-width: 900px; margin: 0 auto; padding: 20px; }
        .message { padding: 10px; margin-bottom: 15px; border-radius: 4px; }
        .success { background: #d4edda; color: #155724; }
        .error { background: #f8d7da; color: #721c24; }
        table { width: 100%; border-collapse: collapse; margin-top: 20px; }
        th, td { border: 1px solid #ddd; padding: 10px; text-align: left; }
        th { background: #007bff; color: white; }
        a { margin-right: 10px; }
        .btn { padding: 5px 10px; text-decoration: none; border-radius: 4px; }
        .btn-primary { background: #007bff; color: white; }
        .btn-danger { background: #dc3545; color: white; }
        .btn-info { background: #17a2b8; color: white; }
        form { margin-bottom: 20px; }
        input, textarea { padding: 8px; margin-right: 10px; }
    </style>
</head>
<body>
    <h1>Gestión de Productos</h1>
    
    <?php if ($message): ?>
        <div class="message <?= htmlspecialchars($type) ?>"><?= htmlspecialchars($message) ?></div>
    <?php endif; ?>

    <h2>Agregar Producto</h2>
    <form action="?action=create" method="POST">
        <input type="text" name="nombre" placeholder="Nombre" required>
        <input type="text" name="descripcion" placeholder="Descripción" required>
        <input type="number" name="cantidad" placeholder="Existencia" required>
        <input type="number" step="0.01" name="precio" placeholder="Precio" required>
        <button type="submit" class="btn btn-primary">Agregar</button>
    </form>

    <h2>Lista de Productos</h2>
    <table>
        <thead>
            <tr>
                <th>ID</th>
                <th>Nombre</th>
                <th>Descripción</th>
                <th>Existencia</th>
                <th>Precio</th>
                <th>Acciones</th>
            </tr>
        </thead>
        <tbody>
            <?php foreach ($productos as $producto): ?>
            <tr>
                <td><?= htmlspecialchars($producto->getId()) ?></td>
                <td><?= htmlspecialchars($producto->getNombre()) ?></td>
                <td><?= htmlspecialchars($producto->getDescripcion()) ?></td>
                <td><?= htmlspecialchars($producto->getStock()) ?></td>
                <td>$<?= number_format($producto->getPrecio(), 2) ?></td>
                <td>
                    <a href="?action=edit&id=<?= $producto->getId() ?>" class="btn btn-info">Editar</a>
                    <a href="?action=delete&id=<?= $producto->getId() ?>" class="btn btn-danger" onclick="return confirm('¿Eliminar?')">Eliminar</a>
                </td>
            </tr>
            <?php endforeach; ?>
            <?php if (empty($productos)): ?>
            <tr><td colspan="6">No hay productos</td></tr>
            <?php endif; ?>
        </tbody>
    </table>
</body>
</html>