<body>
    <h1>Editar Producto</h1>
    
    <form action="?action=update&id=<?= htmlspecialchars($producto->getId()) ?>" method="POST">
        <div>
            <label for="nombre">Nombre:</label>
            <input type="text" id="nombre" name="nombre" value="<?= htmlspecialchars($producto->getNombre()) ?>" required>
        </div>
        <div>
            <label for="descripcion">Descripción:</label>
            <textarea id="descripcion" name="descripcion" required><?= htmlspecialchars($producto->getDescripcion()) ?></textarea>
        </div>
        <div>
            <label for="cantidad">Existencia:</label>
            <input type="number" id="cantidad" name="cantidad" value="<?= htmlspecialchars($producto->getStock()) ?>" required>
        </div>
        <div>
            <label for="precio">Precio:</label>
            <input type="number" step="0.01" id="precio" name="precio" value="<?= htmlspecialchars($producto->getPrecio()) ?>" required>
        </div>
        <button type="submit">Actualizar</button>
        <a href="index.php">Cancelar</a>
    </form>
